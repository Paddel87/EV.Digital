{
  "name": "@ev-digital/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend (Vue 3 + Vuetify 3, PWA) für Einsatzversorgung Digital.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host",
